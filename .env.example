# =============================================================================
# AI Triage Agentic System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI — required for the LLM Explanation Agent and the AutoGen-based
# Clinician Chat Agent (app/agents/autogen_team.py).
# Get these from: Azure Portal → Your OpenAI Resource → Keys and Endpoint
# Without these set, both agents degrade gracefully (NOT_CONFIGURED) rather
# than crashing -- everything else in this project works without them.
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# API base URL
# For local development (default): http://127.0.0.1:8000
# For Azure App Service: https://your-app.azurewebsites.net
# -----------------------------------------------------------------------------
TRIAGE_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Dataset mode
# "demo"  — uses MIMIC-IV-ED Demo (100 patients, public, no credentials needed)
# "full"  — uses MIMIC-IV-ED full dataset (requires PhysioNet approval)
#           Switch to "full" once you have credentials and have downloaded the data.
# -----------------------------------------------------------------------------
ACTIVE_DATASET=kaggle_ktas

# -----------------------------------------------------------------------------
# MIMIC-IV-ED Full Dataset (only needed when ACTIVE_DATASET=full)
# Download from: https://physionet.org/content/mimic-iv-ed/2.2/
# Requires a PhysioNet credentialed account.
# Set this to your PhysioNet username for the download script.
# -----------------------------------------------------------------------------
# PHYSIONET_USERNAME=your-physionet-username

# -----------------------------------------------------------------------------
# Azure Cosmos DB (optional — future phase for production storage)
# -----------------------------------------------------------------------------
# COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_DB_KEY=your-key-here
# COSMOS_DB_DATABASE=ai-triage
# COSMOS_DB_CONTAINER=cases
